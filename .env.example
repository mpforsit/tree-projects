# Environment: development | staging | production.
# db:reset refuses to run when this is "production".
APP_ENV=development

# Owner role — used ONLY by migrations and db:reset (scripts/migrate.ts).
DATABASE_URL_OWNER=postgres://treeops_owner:treeops@localhost:5432/treeops

# Low-privileged app role (RLS FORCEd, no direct DML — spec §12).
# Created by migration 0015; db:reset sets the dev password 'treeops'.
DATABASE_URL=postgres://app_user:treeops@localhost:5432/treeops

# better-auth connection role (sessions, OTP state, OIDC accounts — 0019).
AUTH_DATABASE_URL=postgres://auth_user:treeops@localhost:5432/treeops

# better-auth server config.
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me

# Entra ID (optional; the Microsoft button hides when unset). §8.2:
# explicit tenant allowlist, never "any Microsoft account".
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# SMTP relay for OTP + invitation mail (mailpit locally).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=treeops@example.com
